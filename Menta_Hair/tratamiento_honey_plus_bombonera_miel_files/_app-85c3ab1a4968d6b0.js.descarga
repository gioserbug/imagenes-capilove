ba(5,30,130,1) 0%, rgba(3,15,65,1) 100%);\n        border-radius: 16px;\n        color: white;\n        display: flex;\n        align-items: center;\n    }\n\n    .my-account > h4 {\n        margin: 0px 36px 0px 8px;\n        font-size: 20px;\n        color: white;\n        font-family: 'poppinssemibold';\n        align-self: center;\n    }\n\n    .my-account h3 {\n        font-size: 26px;\n        color: white;\n        font-family: 'poppinssemibold';\n    }\n\n    .sub_right {\n        width: 58%;\n        justify-content: flex-end;\n    }\n\n    .row_location {\n        display: flex;\n        gap: 20px;\n    }\n\n    .location {\n        border-left: 3px solid ",";\n        padding-left: 20px;\n    }\n\n    .header > div {\n        justify-content: space-around;\n    }\n\n    .drawer_row {\n        display: flex;\n        flex-direction: column;\n        justify-content: space-between;\n        height: 100%;\n        text-align: center;\n    }\n\n    .drawer_row a img {\n        max-width: 150px;\n        margin-bottom: 30px;\n    }\n\n    .drawer_row > h4 {\n        color: ",";\n        font-family: 'poppinsbold';\n        font-size: 16px;\n        margin-top: 10px;\n    }\n\n    .ant-drawer-header.ant-drawer-header-close-only {\n        padding: 0;\n        border: none;\n        position: absolute;\n        top: 30px;\n        left: 10px;\n    }\n    \n    .my-account-mobile {\n        line-height: 1.2;\n        padding: 6px;\n        align-self: center;\n        /* margin-left: 30px; */\n        background: rgb(5,30,130);\n        background: linear-gradient(180deg, rgba(5,30,130,1) 0%, rgba(3,15,65,1) 100%);\n        border-radius: 16px;\n        color: white;\n        gap: 10px;\n    }\n\n    .my-account-mobile h4 {\n        /* margin: 0px 12px 0px 4px; */\n        margin-top: 5px;\n        text-align: center;\n        font-size: 13px;\n        color: white;\n        font-family: 'poppinssemibold';\n    }\n\n    .my-account-mobile p {\n        margin: 0px;\n    }\n\n    .my-account-mobile h3 {\n        margin: 0px;\n        font-size: 16px;\n        color: white;\n        font-family: 'poppinssemibold';\n    }\n\n    .cart_header, .my-account {\n        cursor: pointer;\n    }\n    /*********end header*********/\n\n    /*********Footer*********/\n    .logo_footer {\n        margin-bottom: 20px;\n        display: flex;\n        justify-content: center;\n    }\n\n    .icons_footer {\n        display: flex;\n        justify-content: center;\n        gap: 1rem;\n        margin-top: 1rem;\n        margin-bottom: 30px;\n    }\n\n    .icons_footer svg {\n        background: ",";\n        width: 30px;\n        height: 30px;\n        border-radius: 50%;\n        padding: 8px;\n        color: white;\n    }\n\n    .shop-layout footer {\n        background: white;\n        padding: 0;\n        padding-top: 80px;\n    }\n\n    .shop-layout footer > div {\n        /* position: relative; */\n        z-index: 1;\n    }\n\n    .shop-layout footer > div {\n        padding: 0 50px;\n    }\n\n    .shop-layout footer .sub_footer {\n        gap: 8px;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        padding-top: 16px;\n        border-top: 1px solid ",";\n        padding-bottom: 16px;\n    }\n\n    .sub_footer p {\n        margin: 0;\n    }\n\n    /*********end Footer*********/\n\n    .whatsapp_custom {\n        position: fixed;\n        z-index: 9;\n        right: 50px;\n        bottom: 50px;\n    }\n\n    .whatsapp_custom img {\n        width: 60px;\n    }\n\n    /*****Categories img */\n\n    .img_category {\n        width: 100%;\n        box-shadow: 0px 0px 8px #00000027;\n        border-radius: 10px;\n    }\n\n    /* .shop-layout .sidebar {\n        overflow: auto;\n        height: calc(100vh - ","px);\n        position: fixed;\n        left: auto;\n        bottom: 0;\n        border-right: 1.5px solid #cacaca;\n    } */\n\n    .shop-layout .container {\n        max-width: 1440px;\n        margin: 0 auto;\n        padding: 20px 0px;\n        width: 100%;\n        /* margin-top: ","px; */\n    }\n\n    .shop-layout .content-wrapper {\n        margin: 24px 16px;\n        padding-left: 20px;\n        padding-right: 20px;\n    }\n\n    /* .shop-layout .location {\n        display: flex;\n        flex-direction: column;\n        margin-left: 40px;\n        margin-right: 40px;\n    } */\n\n    ::-webkit-scrollbar {\n    width: 5px;\n    }\n\n    ::-webkit-scrollbar-track {\n    background: #f1f1f1;\n    }\n\n    ::-webkit-scrollbar-thumb {\n    background: ",";\n    }\n\n    .swiper-slide{\n        text-align: center;\n    }\n\n    .title_primary { \n        color: ",";\n        font-family: 'poppinsbold';\n        font-size: 24px;\n        margin-bottom: 20px;\n    }\n    \n    .subtitle {\n        color: ",";\n        font-family: 'poppinssemibold';\n        font-size: 16px;\n        margin: 10px 0px;\n    }\n\n    .subtitle_home {         \n        color: ",";\n        font-family: 'poppinsbold';\n        font-size: 24px;\n        margin-bottom: 20px;\n        margin-top: 20px;\n    }\n\n    .ant-btn-primary {\n        background-color: ",";\n        border-color: ",";\n    }\n\n    .ant-btn-primary:hover {\n        background-color: ",";\n        border-color: ",";\n    }\n\n    .btn_degradado {\n        background-image: linear-gradient(to right, #D2829E, #2741cc, #2741cc, #D2829E);\n        background-size: 300% 100%;\n        moz-transition: all .4s ease-in-out;\n        -o-transition: all .4s ease-in-out;\n        -webkit-transition: all .4s ease-in-out;\n        transition: all .4s ease-in-out;\n        border: none;\n        padding: 12px 16px;\n        line-height: 1.2;\n        color: white;\n        font-family: 'poppinsbold';\n        letter-spacing: 1px;\n        font-size: 16px;\n        border-radius: 10px;\n        cursor: pointer;\n    }\n    \n    .btn_degradado:hover {\n        background-position: 100% 0;\n        moz-transition: all .4s ease-in-out;\n        -o-transition: all .4s ease-in-out;\n        -webkit-transition: all .4s ease-in-out;\n        transition: all .4s ease-in-out;\n    }\n\n    .iten_banner {\n        display: flex;\n        gap: 20px;\n        justify-content: center;\n        align-items: center;\n        padding: 10px 0px;\n        margin: 20px 0px;\n        border: 0.5px solid #A7DADB;\n        margin-left: -1000px;\n        padding-left: 1000px;\n        margin-right: -1000px;\n        padding-right: 1000px;\n    }\n\n    .iten_banner span {\n        font-family: 'poppinsbold';\n        font-size: 30px;\n    }\n\n    .ant-layout-content{\n       background-color: #FCFCFC;\n    }\n\n    .header_desktop {\n        flex-wrap: wrap;\n        justify-content: center;\n        width: 100%;\n    }\n\n    .header_desktop > div {\n        display: flex;\n        align-items: center;\n        width: 30%;\n        gap: 30px;\n        height: 100%;\n        /* justify-content: space-between; */\n    }\n\n    .header_desktop > div:last-child {\n        width: 70%;\n        justify-content: end;\n        /* justify-content: space-between; */\n    }\n    \n    /* @media (min-width: 1920px) {\n        .container, .shop-layout .header {\n            max-width: 1920px;\n        }\n    } */\n    @media (max-width: 1500px){\n        .sub_right {\n            width: 80%;\n        }\n        .shop-layout .container {\n            max-width: 85%;\n        }\n    }\n    @media (max-width: 1450px) {\n        /* .shop-layout .container {\n            padding: 0px 30px;\n        } */\n        .logo {\n            height: 70%;\n            margin: 0 20px;\n        }\n        .shop-layout .header .search {\n            width: 22%;\n        }\n    }\n    @media (max-width: 1321px){\n        .sub_right {\n            width: 90%;\n        }\n    }\n    @media (max-width: 1200px){\n        .location {\n            display: none;\n        }\n    }\n    @media (max-width: 900px) {\n        .shop-layout .container {\n            /* padding: 0px 30px; */\n            width: 100%;\n            max-width: 100%;\n        }\n        .shop-layout .sidebar, .header > .logo, .header > .search, .header > .sub_right, .header_desktop  {\n            display: none !important;\n        }\n        .shop-layout .content-wrapper {\n            margin: 20px 0px;\n            padding-left: 15px;\n            padding-right: 15px;\n        }\n        .shop-layout footer > div{\n            padding: 0 15px; \n        }\n        .shop-layout footer .sub_footer {\n            /* flex-direction: column; */\n            padding: 10px 15px;\n        }\n        .shop-layout footer .sub_footer {\n            line-height: 1;\n            font-size: 11px;\n            display: flex;\n            flex-wrap: wrap;\n            /* flex-direction: row; */\n        }\n        .sub_footer ul {\n            margin-bottom: 10px;\n        }\n        .sub_footer ul li {\n            margin-right: 0px;\n            text-align: center;\n            margin: 0px 6px;\n        }\n        footer > div {\n            text-align: center;\n        }\n        .icons_footer {\n            margin-bottom: 1.5rem;\n        }\n        .info_footer > div {\n            padding: 0;\n            border: none;\n        }\n        .info_footer h4 {\n            margin-bottom: 0px;\n        }\n        .info_footer > div h5 {\n            margin-bottom: 4px;\n        }\n        footer h3 {\n            margin-bottom: 4px;\n            font-size: 22px;\n        }\n        .shop-layout .header > div {\n            flex-direction: column;\n        }\n        .shop-layout .header {\n            height: auto;\n        }\n        li.ant-menu-item {\n            background: #f9f9f9;\n            margin-bottom: 2px !important;\n        }\n        .subtitle_home {\n            font-size: 20px;\n            margin-bottom: 10px;\n        }\n        .shop-layout .container {\n            padding: 0px 15px;\n        }\n        .title_primary {\n            font-size: 20px;\n        }\n    }\n    @media (max-width: 600px){\n        .shop-layout .header > div {\n            padding: 0px;\n        }\n        .subtitle {\n            line-height: 1.2;\n        }\n        .iten_banner span {\n            font-size: 16px;\n        }\n        .shop-layout footer {\n           padding-top: 50px;\n        }\n    }\n    html, body {\n    overflow-x: hidden;\n    \n}\n.custom-dropdown-menu {\n    bottom: 0 !important;\n}\n.footer {\n  display: grid;\n  grid-template-columns: repeat(5, 1fr);\n  gap: 10px;\n  padding: 20px;\n  /* margin-bottom: 30px; */\n}\n.footer > div {\n  padding: 10px 20px;\n  h3 {\n    color: ",";\n    font-family: 'poppinsbold';\n  }\n  ul {\n    list-style: none;\n    padding: 0;\n    li {\n        margin-bottom: 6px;\n        cursor: pointer;\n    }\n  }\n  a {\n    color: #444;\n  }\n}\n@media (max-width: 800px){\n    .footer {\n  grid-template-columns: repeat(3, 1fr);\n}\n}\n@media (max-width: 600px){\n    .footer {\n  grid-template-columns: repeat(2, 1fr);\n}\n.btn_degradado {\n    padding: 5px 8px;\n    font-size: 12px;\n}\n.whatsapp_custom {\n            right: 30px;\n            bottom: 30px;\n        }\n        .whatsapp_custom img {\n            width: 50px;\n        }\n        .product .whatsapp_custom {\n            right: 20px;\n            bottom: 80px;\n        }\n    }\n@media (max-width: 500px){\n    .footer {\n  grid-template-columns: repeat(1, 1fr);\n  gap: 0px;\n  > div {\n    padding-bottom: 0px;\n  }\n  .logo_footer {\n    max-width: 180px;\n    margin: 0 auto;\n  }\n}\n}\n/* Custom list address */\n.autocomplete-dropdown-container .items_address {\n    border-bottom: 1px solid #00000077;\n    margin-bottom: 10px;\n    padding-bottom: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    width: 100%;\n    border-radius: 0;\n  }\n  .autocomplete-dropdown-container .items_address p {\n    margin: 0 !important;\n  }\n  .autocomple